<?xml version='1.0' encoding='UTF-8'?>
<root>
 <tabbed_widget name="Main" parent="main_window">
  <Tab containers="1" tab_name="Joint States">
   <Container>
    <DockSplitter orientation="-" sizes="0.5;0.5" count="2">
     <DockArea name="position">
      <plot mode="TimeSeries" style="Lines">
       <curve name="/phantom/joint_states/position[0]" color="#1f77b4"/>
       <curve name="/phantom/joint_states/position[1]" color="#ff7f0e"/>
       <curve name="/phantom/joint_states/position[2]" color="#2ca02c"/>
      </plot>
     </DockArea>
     <DockArea name="velocity">
      <plot mode="TimeSeries" style="Lines">
       <curve name="/phantom/joint_states/velocity[0]" color="#1f77b4"/>
       <curve name="/phantom/joint_states/velocity[1]" color="#ff7f0e"/>
       <curve name="/phantom/joint_states/velocity[2]" color="#2ca02c"/>
      </plot>
     </DockArea>
    </DockSplitter>
   </Container>
  </Tab>
 </tabbed_widget>
 <use_relative_time_offset enabled="1"/>

 <!-- ROS2 topic subscriber plugin -->
 <Plugins>
  <plugin ID="ROS2 Topic Subscriber">
   <enabled>true</enabled>
   <topics>
    <topic>/phantom/joint_states</topic>
   </topics>
   <use_header_stamp>true</use_header_stamp>
   <discard_policy>OLD</discard_policy>
   <max_array_size>100</max_array_size>
  </plugin>
 </Plugins>
</root>
